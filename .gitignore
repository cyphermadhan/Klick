# macOS
.DS_Store

# Xcode user data
xcuserdata/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# Build outputs (from xcodebuild -derivedDataPath build)
build/
DerivedData/

# Swift Package Manager
.swiftpm/
.build/
Packages/

# CocoaPods / Carthage — not used, but future-proof
Pods/
Carthage/Build/

# Secrets / local overrides
*.pem
*.p12
.env
.env.local

# Signing — local team ID lives in Signing.xcconfig (copy from .example)
# so it stays out of source control.
Signing.xcconfig

# xcarchive output
*.xcarchive
*.ipa
relay/node_modules/
